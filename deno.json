{
  "compilerOptions": {
    "strict": true
  },
  "exclude": [
    "docs/",
    "dist/"
  ],
  "tasks": {
    "build:npm": "deno run -A scripts/build_npm.ts"
  },
  "workspace": [
    "./packages/core",
    "./packages/mongodb",
    "./packages/hono",
    "./packages/utils",
    "./packages/eventsourcingdb",
    "./examples/hono-demo",
    "./examples/eventsourcing-demo"
  ],
  "nodeModulesDir": "none",
  "fmt": {
    "include": [
      "examples/",
      "packages/"
    ]
  },
  "lint": {
    "include": [
      "examples/",
      "packages/"
    ]
  },
  "check": {
    "include": [
      "examples/",
      "packages/"
    ]
  },
  "test": {
    "include": [
      "examples/",
      "packages/"
    ]
  }
}