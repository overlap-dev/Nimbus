{
  "asyncapi": "3.0.0",
  "info": {
    "title": "Nimbus Example Gustav",
    "version": "1.0.0",
    "description": "A Nimbus example "
  },
  "defaultContentType": "application/json",
  "servers": {
    "http-api": {
      "host": "api.nimbus.overlp.at",
      "protocol": "https",
      "description": "HTTP Server",
      "security": [
        {
          "$ref": "#/components/securitySchemes/apiKey"
        }
      ]
    }
  },
  "channels": {
    "commands": {
      "address": "/api/command",
      "description": "API to send commands",
      "bindings": {
        "http": {
          "method": "POST"
        }
      },
      "messages": {
        "AddRecipeCommand": {
          "$ref": "#/components/messages/AddRecipeCommand"
        }
      }
    },
    "queries": {
      "address": "/api/query",
      "description": "API to send queries",
      "bindings": {
        "http": {
          "method": "POST"
        }
      }
    }
  },
  "operations": {
    "command": {
      "title": "Command",
      "action": "send",
      "channel": {
        "$ref": "#/channels/commands"
      }
    },
    "query": {
      "title": "Query",
      "action": "send",
      "channel": {
        "$ref": "#/channels/queries"
      }
    }
  },
  "components": {
    "messages": {
      "AddRecipeCommand": {
        "name": "AddRecipeCommand",
        "contentType": "application/cloudevents+json",
        "payload": {
          "$ref": "#/components/schemas/AddRecipeCommand"
        }
      }
    },
    "schemas": {
      "CommandSchema": {
        "$id": "https://api.nimbus.overlap.at/schemas/command/v1",
        "type": "object",
        "required": [
          "specversion",
          "id",
          "correlationid",
          "time",
          "source",
          "type",
          "data"
        ],
        "properties": {
          "specversion": {
            "const": "1.0"
          },
          "id": {
            "type": "string",
            "minLength": 1
          },
          "correlationid": {
            "type": "string",
            "minLength": 1
          },
          "time": {
            "type": "string",
            "format": "date-time",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "format": "uri-reference",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "subject": {
            "type": "string",
            "minLength": 1
          },
          "data": {
            "type": ["object", "string", "number", "array", "boolean"]
          },
          "datacontenttype": {
            "type": "string",
            "minLength": 1
          },
          "dataschema": {
            "type": "string",
            "format": "uri",
            "minLength": 1
          }
        }
      },

      "AddRecipeCommand": {
        "$id": "https://api.nimbus.overlap.at/schemas/add-recipe-command/v1",
        "allOf": [
          { "$ref": "#/components/schemas/CommandSchema" },
          {
            "type": "object",
            "properties": {
              "source": { "const": "https://nimbus.overlap.at" },
              "type": { "const": "at.overlap.nimbus.app-recipe" },
              "data": { "$ref": "#/components/schemas/Recipe" },
              "datacontenttype": { "const": "application/json" },
              "dataschema": {
                "const": "https://api.nimbus.overlap.at/schemas/add-recipe-command/v1"
              }
            }
          }
        ]
      },

      "Recipe": {
        "$id": "https://api.nimbus.overlap.at/schemas/recipe/v1",
        "type": "object",
        "required": ["slug", "name", "instructions", "ingredients"],
        "properties": {
          "slug": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "instructions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "ingredients": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "httpApiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}
