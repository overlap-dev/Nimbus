{
  "name": "nimbus-node-demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node --import tsx --watch --env-file=.env src/main.ts",
    "start": "node --import tsx --env-file=.env src/main.ts",
    "database:seed": "node --import tsx --env-file=.env src/seedCollections.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@nimbus-cqrs/core": "^2.3.0",
    "@nimbus-cqrs/hono": "^2.3.0",
    "@nimbus-cqrs/mongodb": "^2.3.0",
    "@nimbus-cqrs/utils": "^2.3.0",
    "hono": "^4.12.27",
    "mongodb": "7.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}